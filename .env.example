# ── Gateway ─────────────────────────────────────────────────────────────────
API_SERVER_ENABLED=true
API_SERVER_KEY=your-secret-key
API_SERVER_HOST=0.0.0.0
HERMES_HOME=/opt/data

# ── Dev Container ────────────────────────────────────────────────────────────
# Browser access (noVNC: http://localhost:6080/vnc.html, CDP: ws://localhost:9222, VNC: vnc://localhost:5900)
GH_TOKEN=
GITHUB_TOKEN=
TAILSCALE_AUTH_KEY=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
BROWSER_PROFILE_DIR=./browser-profile
BROWSER_RESOLUTION=1920x1080
CDP_PORT=9222
VNC_PORT=5900
NOVNC_PORT=6080

# ── Paths ────────────────────────────────────────────────────────────────────
HOST_WORKSPACE=/home/yoav/workspace
HERMES_WORKSPACE=/home/yoav/workspace
