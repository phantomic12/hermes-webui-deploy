# ── API Keys ────────────────────────────────────────────────────────────
# At minimum you need one LLM provider API key.

MINIMAX_API_KEY=your_minimax_api_key_here
# MINIMAX_API_HOST=https://api.minimax.io/anthropic   # leave default unless you need China region

# ── Optional: Additional Provider Keys ─────────────────────────────────
# Uncomment and fill in as needed. hermes will use whichever ones you have.

# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# XAI_API_KEY=

# ── WebUI / Gateway ──────────────────────────────────────────────────────
# Required for the REST API server that the WebUI connects to.
API_SERVER_ENABLED=true
API_SERVER_KEY=change_me_to_a_random_secret

# Must bind to 0.0.0.0 inside Docker so the port mapping works.
API_SERVER_HOST=0.0.0.0

# ── Paths ───────────────────────────────────────────────────────────────
# Path on your HOST where hermes should look for files / run projects.
# This directory is bind-mounted into the container at /workspace.
HOST_WORKSPACE=${HOME}/projects
