# ── Gateway ─────────────────────────────────────────────────────────────────
API_SERVER_ENABLED=true
API_SERVER_KEY=your-secret-key
API_SERVER_HOST=0.0.0.0
HERMES_HOME=/opt/data

# ── LLM Provider ─────────────────────────────────────────────────────────────
MINIMAX_API_KEY=your-minimax-api-key-here

# ── Cloud Providers ───────────────────────────────────────────────────────────
CAMOFOX_API_KEY=your-camofox-api-key-here
FIRECRAWL_API_KEY=your-firecrawl-api-key-here

# ── Browser (dev container) ──────────────────────────────────────────────────
# Browser access: noVNC http://localhost:6080/vnc.html | CDP ws://localhost:9222 | VNC vnc://localhost:5900
GH_TOKEN=your-gh-token-here
TAILSCALE_AUTH_KEY=your-tailscale-auth-key-here
CLOUDFLARE_API_KEY=your-cloudflare-api-key-here
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id-here
BROWSER_PROFILE_DIR=./browser-profile
BROWSER_RESOLUTION=1920x1080
CDP_PORT=9222
VNC_PORT=5900
NOVNC_PORT=6080

# ── Paths ───────────────────────────────────────────────────────────────────
HOST_WORKSPACE=${HOME}/workspace
HERMES_WORKSPACE=${HOME}/workspace
